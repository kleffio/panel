# Platform API base URL (server-side proxy rewrites — use Docker DNS when containerised)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# OIDC / Identity provider settings (works with any OIDC-compliant provider)
NEXT_PUBLIC_OIDC_AUTHORITY=http://localhost:8180/realms/kleff
NEXT_PUBLIC_OIDC_CLIENT_ID=kleff-panel

# ── Auth UI mode ───────────────────────────────────────────────────────────────
# Controls how users authenticate and register.
#
#   panel    (default) — Kleff renders its own login and sign-up forms.
#                        Login uses ROPC (direct credentials to your IDP token endpoint).
#                        Sign-up posts to REGISTRATION_WEBHOOK_URL on the platform API.
#                        Best when you want a fully branded, seamless experience.
#
#   redirect            — All auth is delegated to your identity provider.
#                        Users are redirected to the IDP's own login / registration pages.
#                        Works out of the box with any OIDC provider, no webhook needed.
#
NEXT_PUBLIC_AUTH_MODE=panel