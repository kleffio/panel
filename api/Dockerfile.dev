# Development image — uses Air for live reload on source changes.
# Build context: panel/api/
# Source is volume-mounted at /app by docker compose.
FROM golang:1.25-alpine

RUN apk add --no-cache git curl ca-certificates

ENV GOTOOLCHAIN=auto
RUN go install github.com/air-verse/air@latest && \
    go install github.com/go-delve/delve/cmd/dlv@latest

WORKDIR /app

# Pre-download workspace dependencies for faster first-run.
COPY go.work go.work.sum ./
COPY go.mod go.sum ./
COPY packages/go.mod packages/

RUN GOWORK=off go mod download

EXPOSE 8080 2345

CMD ["air", "-c", ".air.toml"]
